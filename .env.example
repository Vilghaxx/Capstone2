# ===== Dental System — Environment Configuration =====
# Copy this file to `.env` and fill in the values for your deployment.

# ----- Database -----
# SQLite (development / single-server deployment):
DATABASE_URL="file:./db/custom.db"
#
# PostgreSQL (production / multi-instance — update prisma/schema.prisma provider to "postgresql"):
# DATABASE_URL="postgresql://user:password@localhost:5432/dental_system?schema=public"

# ----- Authentication -----
# JWT secret for signing auth tokens. Generate with: openssl rand -base64 32
JWT_SECRET="change-me-to-a-long-random-secret"

# ----- Application -----
# Set to "production" to disable dev-only features
NODE_ENV="development"
