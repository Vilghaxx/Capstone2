// Dental Practice Management System - Prisma Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(cuid())
  username   String   @unique
  password   String   // bcrypt hash
  role       String   // dentist | cashier | patient
  name       String
  patientRef String?  // link to Patient.id for patient users
  createdAt  DateTime @default(now())
}

model Patient {
  id          String   @id @default(cuid())
  name        String
  phone       String
  email       String
  dateOfBirth String
  address     String   @default("")
  notes       String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Tooth {
  id                String    @id @default(cuid())
  patientId         String
  toothNumber       Int
  status            String    // healthy | treated | needs-attention | urgent
  lastTreatment     String?
  lastTreatmentDate DateTime?
  notes             String?
  updatedAt         DateTime  @updatedAt

  @@unique([patientId, toothNumber])
  @@index([patientId])
}

model Treatment {
  id            String    @id @default(cuid())
  patientId     String
  toothNumber   Int
  procedure     String
  notes         String    @default("")
  cost          Float
  followUpDate  String?
  date          DateTime  @default(now())
  createdAt     DateTime  @default(now())
  dentistId     String
  dentistName   String
  paid          Boolean   @default(false)
  paidAt        DateTime?
  paidBy        String?
  paymentMethod String?
  paidAmount    Float?

  @@index([patientId])
  @@index([toothNumber])
  @@index([patientId, toothNumber])
}

model Appointment {
  id        String   @id @default(cuid())
  patientId String
  date      DateTime
  time      String
  type      String
  status    String   // pending | scheduled | completed | cancelled | no-show
  notes     String   @default("")
  createdAt DateTime @default(now())
  createdBy String
  updatedAt DateTime @updatedAt

  @@index([patientId])
  @@index([status])
  @@index([date])
}
